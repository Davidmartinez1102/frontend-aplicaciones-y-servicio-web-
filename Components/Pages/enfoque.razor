@page "/enfoque"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Enfoques</PageTitle>

<div class="container mt-4">
    <h3>Gestión de Enfoques</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Enfoque</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white">
                @(editando ? "Editar Enfoque" : "Nuevo Enfoque")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Descripción</label>
                        <input class="form-control" @bind="campoDescripcion" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (registros.Any() && !mostrarFormulario)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerValor(reg, "id")</td>
                        <td>@ObtenerValor(reg, "nombre")</td>
                        <td>@ObtenerValor(reg, "descripcion")</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (!mostrarFormulario)
    {
        <div class="alert alert-warning">No hay enfoques registrados.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoId = 0;
    private string campoNombre = string.Empty;
    private string campoDescripcion = string.Empty;

    protected override async Task OnInitializedAsync() => await CargarRegistros();

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("enfoque") ?? new();
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = 0;
        campoNombre = string.Empty;
        campoDescripcion = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(ObtenerValor(reg, "id"), out int id) ? id : 0;
        campoNombre = ObtenerValor(reg, "nombre");
        campoDescripcion = ObtenerValor(reg, "descripcion");
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrWhiteSpace(campoNombre) || string.IsNullOrWhiteSpace(campoDescripcion))
        {
            exito = false; mensaje = "Nombre y descripción son obligatorios."; return;
        }

        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["nombre"] = campoNombre,
            ["descripcion"] = campoDescripcion
        };

        if (editando)
        {
            datos.Remove("id");
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Actualizar Enfoque #{campoId}?");
            if (!confirmar) return;
            var r = await Api.ActualizarAsync("enfoque", "id", campoId.ToString(), datos);
            exito = r.exito; mensaje = r.mensaje;
        }
        else
        {
            var r = await Api.CrearAsync("enfoque", datos);
            exito = r.exito; mensaje = r.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string idStr = ObtenerValor(reg, "id");
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar Enfoque #{idStr}?");
        if (!confirmar) return;
        var r = await Api.EliminarAsync("enfoque", "id", idStr);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerValor(Dictionary<string, object?> dic, string clave)
    {
        if (dic.TryGetValue(clave, out var val) && val != null) return val.ToString() ?? "";
        return "";
    }
}
