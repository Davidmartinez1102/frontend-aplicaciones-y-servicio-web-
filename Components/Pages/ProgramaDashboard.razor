@page "/dashboard-programas"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS
@using System.Text.Json

<PageTitle>Dashboard Programas</PageTitle>

<style>
    /* ═══════════════════════════════════════════════
       DESIGN SYSTEM — Dashboard Programas Unificado
       Tema: Dark luxury con acentos jade
    ═══════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --jade:        #2ecc8f;
        --jade-dim:    #1a9e6a;
        --jade-glow:   rgba(46,204,143,.15);
        --sapphire:    #4ea8de;
        --amber:       #f5a623;
        --rose:        #e05c6e;
        --violet:      #a78bfa;
        --bg-900:      #0d1117;
        --bg-800:      #161b22;
        --bg-700:      #1c2230;
        --bg-600:      #243040;
        --border:      rgba(255,255,255,.07);
        --border-md:   rgba(255,255,255,.12);
        --text-hi:     #e6edf3;
        --text-mid:    #8b949e;
        --text-lo:     #484f58;
        --radius:      12px;
        --radius-sm:   8px;
        --shadow:      0 8px 32px rgba(0,0,0,.45);
        --shadow-lg:   0 20px 60px rgba(0,0,0,.6);
        --transition:  .2s cubic-bezier(.4,0,.2,1);
        --panel-width: 520px;
    }

    *, *::before, *::after { box-sizing: border-box; }

    .dash-root {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg-900);
        color: var(--text-hi);
        min-height: 100vh;
        padding: 0;
        margin: -16px;
        position: relative;
        overflow-x: hidden;
    }

    /* ── HEADER ─────────────────────────────────── */
    .dash-header {
        background: linear-gradient(135deg, var(--bg-800) 0%, var(--bg-700) 100%);
        border-bottom: 1px solid var(--border);
        padding: 24px 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(12px);
    }
    .dash-header::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 400px 200px at 80% 50%, var(--jade-glow), transparent);
        pointer-events: none;
    }
    .header-left { display: flex; align-items: center; gap: 16px; }
    .dash-logo {
        width: 42px; height: 42px;
        background: linear-gradient(135deg, var(--jade), var(--sapphire));
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
        box-shadow: 0 4px 16px rgba(46,204,143,.3);
    }
    .dash-title h1 {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem; font-weight: 700;
        margin: 0; color: var(--text-hi); letter-spacing: -.3px;
    }
    .dash-title p { margin: 2px 0 0; color: var(--text-mid); font-size: .8rem; }
    .header-stats { display: flex; gap: 24px; }
    .hstat { text-align: center; }
    .hstat-val { font-size: 1.4rem; font-weight: 700; color: var(--jade); line-height: 1; }
    .hstat-lbl { font-size: .68rem; color: var(--text-lo); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }

    /* ── TOOLBAR ─────────────────────────────────── */
    .dash-toolbar {
        padding: 20px 40px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--border);
        background: var(--bg-800);
    }
    .search-box {
        flex: 1; max-width: 360px;
        background: var(--bg-900);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        display: flex; align-items: center; gap: 10px;
        padding: 9px 14px;
        transition: border-color var(--transition);
    }
    .search-box:focus-within { border-color: var(--jade); box-shadow: 0 0 0 3px var(--jade-glow); }
    .search-box input {
        background: none; border: none; outline: none;
        color: var(--text-hi); font-family: 'DM Sans', sans-serif;
        font-size: .85rem; width: 100%;
    }
    .search-box input::placeholder { color: var(--text-lo); }
    .search-icon { color: var(--text-lo); font-size: .9rem; }

    /* ── ALERT ──────────────────────────────────── */
    .dash-alert {
        margin: 0 40px 0;
        padding: 11px 16px;
        border-radius: var(--radius-sm);
        font-size: .84rem;
        display: flex; align-items: center; gap: 10px;
        animation: slideDown .25s ease;
    }
    .dash-alert.ok  { background: rgba(46,204,143,.1); border: 1px solid rgba(46,204,143,.25); color: #6ee7b7; }
    .dash-alert.err { background: rgba(224,92,110,.1); border: 1px solid rgba(224,92,110,.25); color: #fca5a5; }
    .dash-alert-close { margin-left: auto; background: none; border: none; color: inherit; cursor: pointer; opacity: .6; font-size: 1rem; padding: 0 4px; }
    .dash-alert-close:hover { opacity: 1; }

    /* ── MAIN ────────────────────────────────────── */
    .dash-main { padding: 28px 40px; }

    /* ── TABLA MAESTRA ──────────────────────────── */
    .master-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: var(--bg-800);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--shadow);
    }
    .master-table thead tr { background: var(--bg-700); }
    .master-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: .7rem; font-weight: 500;
        text-transform: uppercase; letter-spacing: 1.2px;
        color: var(--text-mid);
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }
    .master-table th.th-center { text-align: center; }

    /* Fila principal del programa */
    .row-programa td {
        padding: 14px 16px;
        font-size: .85rem;
        color: var(--text-hi);
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
        transition: background var(--transition);
    }
    .row-programa:hover td { background: rgba(255,255,255,.02); }
    .row-programa.expanded td { background: var(--bg-700); border-bottom-color: transparent; }

    /* Botón expandir */
    .btn-expand {
        background: none; border: none; cursor: pointer;
        color: var(--text-lo); font-size: .9rem;
        padding: 4px 8px; border-radius: 6px;
        transition: all var(--transition);
        display: inline-flex; align-items: center;
    }
    .btn-expand:hover { color: var(--jade); background: var(--jade-glow); }
    .btn-expand.open { color: var(--jade); transform: rotate(0deg); }
    .expand-chevron { display: inline-block; transition: transform .2s ease; }
    .btn-expand.open .expand-chevron { transform: rotate(90deg); }

    /* Nombre del programa */
    .prog-name { font-weight: 600; color: var(--text-hi); }
    .prog-id { font-size: .72rem; color: var(--text-lo); margin-top: 1px; }

    /* Badges de relaciones */
    .rel-badges { display: flex; gap: 5px; flex-wrap: wrap; }
    .rbadge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 8px; border-radius: 20px;
        font-size: .7rem; font-weight: 500; white-space: nowrap;
        cursor: default;
    }
    .rbadge-an  { background: rgba(245,166,35,.12);  color: var(--amber);    border: 1px solid rgba(245,166,35,.2); }
    .rbadge-pe  { background: rgba(78,168,222,.12);  color: var(--sapphire); border: 1px solid rgba(78,168,222,.2); }
    .rbadge-ac  { background: rgba(46,204,143,.12);  color: var(--jade);     border: 1px solid rgba(46,204,143,.2); }
    .rbadge-ci  { background: rgba(167,139,250,.12); color: var(--violet);   border: 1px solid rgba(167,139,250,.2); }

    /* Acciones inline */
    .cell-actions { display: flex; gap: 6px; justify-content: flex-end; }
    .btn-icon {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-mid);
        padding: 5px 10px;
        border-radius: 6px;
        cursor: pointer;
        font-size: .76rem;
        transition: all var(--transition);
        display: inline-flex; align-items: center; gap: 4px;
    }
    .btn-icon.info:hover    { background: rgba(78,168,222,.12);  color: var(--sapphire); border-color: rgba(78,168,222,.4); }
    .btn-icon.warn:hover    { background: rgba(245,166,35,.12);  color: var(--amber);    border-color: rgba(245,166,35,.4); }
    .btn-icon.danger:hover  { background: rgba(224,92,110,.12);  color: var(--rose);     border-color: rgba(224,92,110,.4); }

    /* ── FILA EXPANDIDA ─────────────────────────── */
    .row-expanded td {
        padding: 0;
        border-bottom: 1px solid var(--border);
        background: var(--bg-700);
    }
    .expand-panel {
        padding: 20px 24px 24px 52px;
        animation: expandIn .2s ease;
    }
    .expand-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .expand-section {
        background: var(--bg-800);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        overflow: hidden;
    }
    .expand-section-header {
        padding: 10px 14px;
        display: flex; align-items: center; justify-content: space-between;
        border-bottom: 1px solid var(--border);
        font-size: .75rem; font-weight: 500;
        text-transform: uppercase; letter-spacing: .8px;
    }
    .expand-section-header.an { color: var(--amber);    background: rgba(245,166,35,.05); }
    .expand-section-header.pe { color: var(--sapphire); background: rgba(78,168,222,.05); }
    .expand-section-header.ac { color: var(--jade);     background: rgba(46,204,143,.05); }
    .expand-section-header.ci { color: var(--violet);   background: rgba(167,139,250,.05); }

    .expand-section-body { padding: 10px 14px; }
    .expand-item {
        display: flex; align-items: center; justify-content: space-between;
        padding: 6px 0;
        border-bottom: 1px solid var(--border);
        font-size: .8rem; color: var(--text-mid);
        gap: 8px;
    }
    .expand-item:last-child { border-bottom: none; padding-bottom: 0; }
    .expand-item-name { color: var(--text-hi); flex: 1; }
    .expand-empty { color: var(--text-lo); font-size: .78rem; font-style: italic; padding: 4px 0; }

    .btn-add-rel {
        background: none; border: none; cursor: pointer;
        color: inherit; opacity: .6; font-size: .8rem;
        padding: 2px 6px; border-radius: 4px;
        transition: all var(--transition);
    }
    .btn-add-rel:hover { opacity: 1; background: rgba(255,255,255,.08); }
    .btn-del-rel {
        background: none; border: none; cursor: pointer;
        color: var(--text-lo); font-size: .75rem;
        padding: 2px 5px; border-radius: 4px;
        transition: all var(--transition);
        flex-shrink: 0;
    }
    .btn-del-rel:hover { color: var(--rose); }

    /* ── PANEL LATERAL ──────────────────────────── */
    .panel-overlay {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.6);
        backdrop-filter: blur(4px);
        z-index: 200;
        animation: fadeIn .2s ease;
    }
    .side-panel {
        position: fixed;
        top: 0; right: 0; bottom: 0;
        width: var(--panel-width);
        background: var(--bg-800);
        border-left: 1px solid var(--border-md);
        box-shadow: var(--shadow-lg);
        z-index: 201;
        display: flex; flex-direction: column;
        animation: slidePanel .25s cubic-bezier(.4,0,.2,1);
        overflow: hidden;
    }
    .panel-header {
        padding: 20px 24px;
        background: var(--bg-700);
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 12px;
        flex-shrink: 0;
    }
    .panel-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--jade); box-shadow: 0 0 8px var(--jade);
    }
    .panel-header h3 { margin: 0; font-size: 1rem; font-weight: 500; }
    .panel-header p  { margin: 2px 0 0; font-size: .75rem; color: var(--text-mid); }
    .btn-close-panel {
        margin-left: auto; background: none; border: none;
        color: var(--text-mid); cursor: pointer; font-size: 1.1rem;
        padding: 4px 8px; border-radius: 6px; transition: all var(--transition);
    }
    .btn-close-panel:hover { color: var(--text-hi); background: var(--bg-600); }

    /* Tabs del panel */
    .panel-tabs {
        display: flex;
        border-bottom: 1px solid var(--border);
        background: var(--bg-700);
        flex-shrink: 0;
    }
    .panel-tab {
        flex: 1; padding: 11px 8px;
        background: none; border: none; cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        font-size: .78rem; color: var(--text-mid);
        border-bottom: 2px solid transparent;
        transition: all var(--transition);
    }
    .panel-tab:hover { color: var(--text-hi); background: rgba(255,255,255,.03); }
    .panel-tab.active { color: var(--jade); border-bottom-color: var(--jade); font-weight: 500; }

    .panel-body {
        flex: 1; overflow-y: auto; padding: 24px;
    }
    .panel-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex; gap: 10px;
        flex-shrink: 0;
        background: var(--bg-800);
    }

    /* ── FORM ELEMENTS ──────────────────────────── */
    .form-row { display: grid; gap: 14px; margin-bottom: 14px; }
    .form-row.cols-2 { grid-template-columns: 1fr 1fr; }
    .form-row.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-label {
        font-size: .7rem; font-weight: 500;
        color: var(--text-mid); text-transform: uppercase; letter-spacing: .6px;
    }
    .form-input, .form-select {
        background: var(--bg-900) !important;
        border: 1px solid var(--border) !important;
        border-radius: var(--radius-sm) !important;
        color: var(--text-hi) !important;
        padding: 8px 12px !important;
        font-family: 'DM Sans', sans-serif !important;
        font-size: .84rem !important;
        transition: border-color var(--transition) !important;
        outline: none !important;
        width: 100%;
    }
    .form-input:focus, .form-select:focus {
        border-color: var(--jade) !important;
        box-shadow: 0 0 0 3px var(--jade-glow) !important;
    }
    .form-select option { background: var(--bg-700); }

    /* Sub-sección de premios / pasantías en el panel */
    .panel-subsection { margin-bottom: 20px; }
    .panel-subsection-title {
        font-size: .75rem; font-weight: 500;
        text-transform: uppercase; letter-spacing: .8px;
        padding-bottom: 8px; margin-bottom: 10px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 8px;
    }
    .detail-row-grid {
        background: var(--bg-700);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 10px 12px;
        margin-bottom: 8px;
        display: grid; gap: 8px;
        animation: slideIn .2s ease;
    }
    .detail-row-grid.cols-4 { grid-template-columns: 1fr 1fr 1fr 1fr auto; align-items: end; }

    .btn-add-row {
        background: transparent; border: 1px dashed var(--border);
        color: var(--text-mid); font-size: .78rem;
        padding: 7px 14px; border-radius: var(--radius-sm);
        cursor: pointer; width: 100%; text-align: center;
        transition: all var(--transition); margin-top: 4px;
    }
    .btn-add-row:hover { border-color: var(--jade); color: var(--jade); background: var(--jade-glow); }

    /* ── BUTTONS ─────────────────────────────────── */
    .btn-jade {
        background: linear-gradient(135deg, var(--jade), var(--jade-dim));
        color: #0d1117; font-family: 'DM Sans', sans-serif;
        font-size: .83rem; font-weight: 600; border: none;
        padding: 9px 18px; border-radius: var(--radius-sm);
        cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
        transition: all var(--transition);
        box-shadow: 0 4px 14px rgba(46,204,143,.25);
    }
    .btn-jade:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(46,204,143,.35); }
    .btn-ghost {
        background: transparent; border: 1px solid var(--border);
        color: var(--text-mid); font-family: 'DM Sans', sans-serif;
        font-size: .83rem; padding: 9px 18px;
        border-radius: var(--radius-sm); cursor: pointer;
        transition: all var(--transition);
    }
    .btn-ghost:hover { background: var(--bg-700); color: var(--text-hi); border-color: var(--text-lo); }

    /* Relaciones en panel */
    .rel-panel-item {
        display: flex; align-items: center; justify-content: space-between;
        padding: 9px 12px;
        background: var(--bg-700); border: 1px solid var(--border);
        border-radius: var(--radius-sm); margin-bottom: 6px;
        font-size: .82rem;
        animation: slideIn .15s ease;
    }
    .rel-panel-item-name { color: var(--text-hi); }
    .rel-panel-add {
        display: flex; gap: 10px; margin-top: 10px;
        padding-top: 10px; border-top: 1px solid var(--border);
    }
    .rel-panel-add .form-select { flex: 1; }

    /* ── EMPTY & SPINNER ─────────────────────────── */
    .empty-state {
        text-align: center; padding: 80px 0; color: var(--text-lo);
    }
    .empty-icon { font-size: 2.8rem; margin-bottom: 14px; opacity: .35; }
    .empty-state p { font-size: .9rem; margin: 0; }
    .dash-spinner {
        display: flex; justify-content: center; align-items: center;
        padding: 80px 0; gap: 12px; color: var(--text-mid); font-size: .85rem;
    }
    .spinner-ring {
        width: 26px; height: 26px;
        border: 2px solid var(--border); border-top-color: var(--jade);
        border-radius: 50%; animation: spin .8s linear infinite;
    }

    /* ── SEPARADOR ───────────────────────────────── */
    .panel-sep { border: none; border-top: 1px solid var(--border); margin: 18px 0; }

    /* ── ANIMACIONES ─────────────────────────────── */
    @@keyframes fadeIn     { from { opacity:0 } to { opacity:1 } }
    @@keyframes slideDown  { from { opacity:0; transform:translateY(-6px)  } to { opacity:1; transform:none } }
    @@keyframes slideIn    { from { opacity:0; transform:translateX(-6px)  } to { opacity:1; transform:none } }
    @@keyframes expandIn   { from { opacity:0; transform:translateY(-4px)  } to { opacity:1; transform:none } }
    @@keyframes slidePanel { from { transform:translateX(100%) } to { transform:translateX(0) } }
    @@keyframes spin        { to { transform:rotate(360deg) } }
</style>

<div class="dash-root">

    <!-- ══ HEADER ══════════════════════════════════ -->
    <header class="dash-header">
        <div class="header-left">
            <div class="dash-logo">🎓</div>
            <div class="dash-title">
                <h1>Gestión Académica</h1>
                <p>Programas · Vista unificada con relaciones</p>
            </div>
        </div>
        <div class="header-stats">
            <div class="hstat"><div class="hstat-val">@programas.Count</div><div class="hstat-lbl">Programas</div></div>
            <div class="hstat"><div class="hstat-val">@registrosAN.Count</div><div class="hstat-lbl">AN</div></div>
            <div class="hstat"><div class="hstat-val">@registrosPE.Count</div><div class="hstat-lbl">PE</div></div>
            <div class="hstat"><div class="hstat-val">@registrosAC.Count</div><div class="hstat-lbl">AC</div></div>
            <div class="hstat"><div class="hstat-val">@registrosCI.Count</div><div class="hstat-lbl">CI</div></div>
        </div>
    </header>

    <!-- ══ TOOLBAR ═════════════════════════════════ -->
    <div class="dash-toolbar">
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input placeholder="Buscar programa, nivel, ciudad..." @bind="filtro" @bind:event="oninput" />
        </div>
        <button class="btn-jade" @onclick="AbrirPanelNuevo">＋ Nuevo Programa</button>
    </div>

    <!-- ══ ALERT ═══════════════════════════════════ -->
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div style="padding:12px 40px 0;">
            <div class="dash-alert @(exito ? "ok" : "err")">
                <span>@(exito ? "✓" : "✕")</span>
                <span>@mensaje</span>
                <button class="dash-alert-close" @onclick="() => mensaje = string.Empty">✕</button>
            </div>
        </div>
    }

    <!-- ══ TABLA MAESTRA ════════════════════════════ -->
    <div class="dash-main">
        @if (cargando)
        {
            <div class="dash-spinner"><div class="spinner-ring"></div> Cargando programas...</div>
        }
        else if (!ProgramasFiltrados.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <p>No hay programas que coincidan.</p>
            </div>
        }
        else
        {
            <table class="master-table">
                <thead>
                    <tr>
                        <th style="width:36px;"></th>
                        <th>#</th>
                        <th>Programa</th>
                        <th>Nivel · Tipo</th>
                        <th>Ciudad</th>
                        <th>Premios</th>
                        <th>Pasantías</th>
                        <th>Relaciones</th>
                        <th class="th-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in ProgramasFiltrados)
                    {
                        var pid      = ObtenerValor(p, "id");
                        var expanded = expandidos.Contains(pid);
                        var anList   = RegistrosANDePrograma(pid);
                        var peList   = RegistrosPEDePrograma(pid);
                        var acList   = RegistrosACDePrograma(pid);
                        var ciList   = RegistrosCIDePrograma(pid);

                        <tr class="row-programa @(expanded ? "expanded" : "")">
                            <!-- Expandir -->
                            <td>
                                <button class="btn-expand @(expanded ? "open" : "")"
                                        @onclick="() => ToggleExpand(pid)">
                                    <span class="expand-chevron">▶</span>
                                </button>
                            </td>
                            <!-- ID -->
                            <td><span style="color:var(--text-lo);font-size:.76rem;">@pid</span></td>
                            <!-- Nombre -->
                            <td>
                                <div class="prog-name">@ObtenerValor(p,"nombre")</div>
                                <div class="prog-id">ID Facultad: @ObtenerValor(p,"facultad")</div>
                            </td>
                            <!-- Nivel · Tipo -->
                            <td>
                                <div>@ObtenerValor(p,"nivel")</div>
                                <div style="font-size:.76rem;color:var(--text-mid);">@ObtenerValor(p,"tipo")</div>
                            </td>
                            <!-- Ciudad -->
                            <td>@ObtenerValor(p,"ciudad")</td>
                            <!-- Premios -->
