</div>

<!-- ══ PANEL LATERAL ═══════════════════════════════ -->
@if (panelAbierto)
{
    <div class="panel-overlay" @onclick="CerrarPanel"></div>

    <div class="side-panel" @onclick:stopPropagation>

        <!-- Header del panel -->
        <div class="panel-header">
            <div class="panel-dot"></div>
            <div>
                <h3>@(panelModo == "nuevo" ? "Nuevo Programa" : panelModo == "editar" ? $"Editar · {ObtenerValor(programaActual!,"nombre")}" : $"Relaciones · {ObtenerValor(programaActual!,"nombre")}")</h3>
                <p>@(panelModo == "nuevo" ? "Completa los datos del programa académico" : panelModo == "editar" ? $"ID {ObtenerValor(programaActual!,"id")}" : "Gestiona las relaciones del programa")</p>
            </div>
            <button class="btn-close-panel" @onclick="CerrarPanel">✕</button>
        </div>

        <!-- Tabs solo para editar (incluye relaciones) -->
        @if (panelModo == "editar")
        {
            <div class="panel-tabs">
                <button class="panel-tab @(panelTab == "datos" ? "active" : "")"     @onclick='() => panelTab = "datos"'>📋 Datos</button>
                <button class="panel-tab @(panelTab == "an" ? "active" : "")"        @onclick='() => panelTab = "an"'>📜 AN</button>
                <button class="panel-tab @(panelTab == "pe" ? "active" : "")"        @onclick='() => panelTab = "pe"'>🎯 PE</button>
                <button class="panel-tab @(panelTab == "ac" ? "active" : "")"        @onclick='() => panelTab = "ac"'>🔬 AC</button>
                <button class="panel-tab @(panelTab == "ci" ? "active" : "")"        @onclick='() => panelTab = "ci"'>💡 CI</button>
            </div>
        }

        <!-- Cuerpo del panel -->
        <div class="panel-body">

            @* ── DATOS DEL PROGRAMA ── *@
            @if (panelModo == "nuevo" || (panelModo == "editar" && panelTab == "datos"))
            {
                <div class="form-row cols-2">
                    <div class="form-group" style="grid-column:1/-1">
                        <label class="form-label">Nombre del Programa</label>
                        <input class="form-input" @bind="c_nombre" placeholder="Ej. Ingeniería de Sistemas" />
                    </div>
                </div>
                <div class="form-row cols-2">
                    <div class="form-group">
                        <label class="form-label">Nivel</label>
                        <input class="form-input" @bind="c_nivel" placeholder="Pregrado / Posgrado" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tipo</label>
                        <input class="form-input" @bind="c_tipo" placeholder="Presencial / Virtual" />
                    </div>
                </div>
                <div class="form-row cols-2">
                    <div class="form-group">
                        <label class="form-label">Ciudad</label>
                        <input class="form-input" @bind="c_ciudad" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Facultad</label>
                        <select class="form-select" @bind="c_facultad">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var fac in listaFacultades)
                            { <option value="@fac["id"]">@fac["nombre"]</option> }
                        </select>
                    </div>
                </div>
                <div class="form-row cols-2">
                    <div class="form-group">
                        <label class="form-label">Fecha Creación</label>
                        <input class="form-input" @bind="c_fecha_creacion" placeholder="YYYY-MM-DD" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha Cierre</label>
                        <input class="form-input" @bind="c_fecha_cierre" placeholder="YYYY-MM-DD" />
                    </div>
                </div>
                <div class="form-row cols-2">
                    <div class="form-group">
                        <label class="form-label">Nº Cohortes</label>
                        <input class="form-input" @bind="c_numero_cohortes" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Cant. Graduados</label>
                        <input class="form-input" @bind="c_cant_graduados" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Última Actualización</label>
                        <input class="form-input" @bind="c_fecha_actualizacion" placeholder="YYYY-MM-DD" />
                    </div>
                </div>

                <hr class="panel-sep" />

                <!-- PREMIOS -->
                <div class="panel-subsection">
                    <div class="panel-subsection-title" style="color:var(--jade)">🏆 Premios</div>
                    @for (int i = 0; i < filasPremios.Count; i++)
                    {
                        var idx = i;
                        <div class="detail-row-grid cols-4">
                            <div class="form-group"><label class="form-label">Nombre</label>
                                <input class="form-input" @bind="filasPremios[idx].Nombre" /></div>
                            <div class="form-group"><label class="form-label">Entidad</label>
                                <input class="form-input" @bind="filasPremios[idx].EntidadOtorgante" /></div>
                            <div class="form-group"><label class="form-label">País</label>
                                <input class="form-input" @bind="filasPremios[idx].Pais" /></div>
                            <div class="form-group"><label class="form-label">Fecha</label>
                                <input class="form-input" type="date" @bind="filasPremios[idx].Fecha" /></div>
                            <div style="display:flex;align-items:flex-end;">
                                <button class="btn-icon danger" style="width:100%;justify-content:center;"
                                        @onclick="() => filasPremios.RemoveAt(idx)">✕</button>
                            </div>
                        </div>
                    }
                    <button class="btn-add-row" @onclick="() => filasPremios.Add(new())">＋ Premio</button>
                </div>

                <!-- PASANTÍAS -->
                <div class="panel-subsection">
                    <div class="panel-subsection-title" style="color:var(--sapphire)">💼 Pasantías</div>
                    @for (int i = 0; i < filasPasantias.Count; i++)
                    {
                        var idx = i;
                        <div class="detail-row-grid cols-4">
                            <div class="form-group"><label class="form-label">Nombre</label>
                                <input class="form-input" @bind="filasPasantias[idx].Nombre" /></div>
                            <div class="form-group"><label class="form-label">Empresa</label>
                                <input class="form-input" @bind="filasPasantias[idx].Empresa" /></div>
                            <div class="form-group"><label class="form-label">País</label>
                                <input class="form-input" @bind="filasPasantias[idx].Pais" /></div>
                            <div class="form-group"><label class="form-label">Descripción</label>
                                <input class="form-input" @bind="filasPasantias[idx].Descripcion" /></div>
                            <div style="display:flex;align-items:flex-end;">
                                <button class="btn-icon danger" style="width:100%;justify-content:center;"
                                        @onclick="() => filasPasantias.RemoveAt(idx)">✕</button>
                            </div>
                        </div>
                    }
                    <button class="btn-add-row" @onclick="() => filasPasantias.Add(new())">＋ Pasantía</button>
                </div>
            }

            @* ── TAB AN ── *@
            @if (panelModo == "editar" && panelTab == "an")
            {
                var pid = ObtenerValor(programaActual!, "id");
                var anList = RegistrosANDePrograma(pid);
                @foreach (var r in anList)
                {
                    <div class="rel-panel-item">
                        <span class="rel-panel-item-name">@ObtenerEtiquetaAspectoById(ObtenerValor(r,"aspecto_normativo"))</span>
                        <button class="btn-del-rel" @onclick="() => EliminarAN(r)">✕ Quitar</button>
                    </div>
                }
                @if (!anList.Any()) { <div class="expand-empty" style="margin-bottom:10px;">Sin relaciones AN.</div> }
                <div class="rel-panel-add">
                    <select class="form-select" @bind="campoAN_Asp">
                        <option value="0">-- Aspecto Normativo --</option>
                        @foreach (var a in aspectos)
                        { <option value="@ObtenerValor(a,"id")">@ObtenerEtiquetaAspecto(a)</option> }
                    </select>
                    <button class="btn-jade" @onclick="GuardarAN">＋</button>
                </div>
            }

            @* ── TAB PE ── *@
            @if (panelModo == "editar" && panelTab == "pe")
            {
                var pid = ObtenerValor(programaActual!, "id");
                var peList = RegistrosPEDePrograma(pid);
                @foreach (var r in peList)
                {
                    <div class="rel-panel-item">
                        <span class="rel-panel-item-name">@ObtenerNombreEnLista(practicasEstrategia,"id",ObtenerValor(r,"practica_estrategia"),"nombre")</span>
                        <button class="btn-del-rel" @onclick="() => EliminarPE(r)">✕ Quitar</button>
                    </div>
                }
                @if (!peList.Any()) { <div class="expand-empty" style="margin-bottom:10px;">Sin relaciones PE.</div> }
                <div class="rel-panel-add">
                    <select class="form-select" @bind="campoPE_Prac">
                        <option value="0">-- Práctica Estrategia --</option>
                        @foreach (var pe in practicasEstrategia)
                        { <option value="@ObtenerValor(pe,"id")">@ObtenerValor(pe,"nombre")</option> }
                    </select>
                    <button class="btn-jade" @onclick="GuardarPE">＋</button>
                </div>
            }

            @* ── TAB AC ── *@
            @if (panelModo == "editar" && panelTab == "ac")
            {
                var pid = ObtenerValor(programaActual!, "id");
                var acList = RegistrosACDePrograma(pid);
                @foreach (var r in acList)
                {
                    <div class="rel-panel-item">
                        <span class="rel-panel-item-name">@ObtenerEtiquetaAreaById(ObtenerValor(r,"area_conocimiento"))</span>
                        <button class="btn-del-rel" @onclick="() => EliminarAC(r)">✕ Quitar</button>
                    </div>
                }
                @if (!acList.Any()) { <div class="expand-empty" style="margin-bottom:10px;">Sin relaciones AC.</div> }
                <div class="rel-panel-add">
                    <select class="form-select" @bind="campoAC_Area">
                        <option value="0">-- Área de Conocimiento --</option>
                        @foreach (var a in areas)
                        { <option value="@ObtenerValor(a,"id")">@ObtenerEtiquetaArea(a)</option> }
                    </select>
                    <button class="btn-jade" @onclick="GuardarAC">＋</button>
                </div>
            }

            @* ── TAB CI ── *@
            @if (panelModo == "editar" && panelTab == "ci")
            {
                var pid = ObtenerValor(programaActual!, "id");
                var ciList = RegistrosCIDePrograma(pid);
                @foreach (var r in ciList)
                {
                    <div class="rel-panel-item">
                        <span class="rel-panel-item-name">@ObtenerNombreEnLista(carInnovaciones,"id",ObtenerValor(r,"car_innovacion"),"nombre")</span>
                        <button class="btn-del-rel" @onclick="() => EliminarCI(r)">✕ Quitar</button>
                    </div>
                }
                @if (!ciList.Any()) { <div class="expand-empty" style="margin-bottom:10px;">Sin relaciones CI.</div> }
                <div class="rel-panel-add">
                    <select class="form-select" @bind="campoCI_Car">
                        <option value="0">-- Característica Innovación --</option>
                        @foreach (var c in carInnovaciones)
                        { <option value="@ObtenerValor(c,"id")">@ObtenerValor(c,"nombre")</option> }
                    </select>
                    <button class="btn-jade" @onclick="GuardarCI">＋</button>
                </div>
            }

        </div>

        <!-- Footer solo para datos -->
        @if (panelModo == "nuevo" || (panelModo == "editar" && panelTab == "datos"))
        {
            <div class="panel-footer">
                <button class="btn-jade" @onclick="GuardarPrograma">💾 Guardar</button>
                <button class="btn-ghost" @onclick="CerrarPanel">Cancelar</button>
            </div>
        }

    </div>
}

@code {

    // ══ ESTADO ═══════════════════════════════════════════════
    private string mensaje  = string.Empty;
    private bool   exito    = false;
    private bool   cargando = true;
    private string filtro   = string.Empty;

    // ── LISTAS MAESTRAS ──────────────────────────────────────
    private List<Dictionary<string, object?>> programas           = new();
    private List<Dictionary<string, object?>> listaFacultades     = new();
    private List<Dictionary<string, object?>> aspectos            = new();
    private List<Dictionary<string, object?>> practicasEstrategia = new();
    private List<Dictionary<string, object?>> areas               = new();
    private List<Dictionary<string, object?>> carInnovaciones     = new();

    // ── RELACIONES ───────────────────────────────────────────
    private List<Dictionary<string, object?>> registrosAN = new();
    private List<Dictionary<string, object?>> registrosPE = new();
    private List<Dictionary<string, object?>> registrosAC = new();
    private List<Dictionary<string, object?>> registrosCI = new();

    // ── EXPANDIDOS ───────────────────────────────────────────
    private HashSet<string> expandidos = new();

    // ── PANEL LATERAL ────────────────────────────────────────
    private bool   panelAbierto = false;
    private string panelModo    = "nuevo";    // nuevo | editar
    private string panelTab     = "datos";    // datos | an | pe | ac | ci
    private Dictionary<string, object?>? programaActual;

    // ── CAMPOS FORMULARIO PROGRAMA ───────────────────────────
    private string c_nombre = "", c_tipo = "", c_nivel = "", c_fecha_creacion = "",
                   c_fecha_cierre = "", c_numero_cohortes = "", c_cant_graduados = "",
                   c_fecha_actualizacion = "", c_ciudad = "";
    private int c_facultad = 0;

    private class PremioFila   { public string Nombre="",Descripcion="N/A",EntidadOtorgante="",Pais=""; public DateTime Fecha=DateTime.Today; }
    private class PasantiaFila { public string Nombre="",Pais="",Empresa="",Descripcion="N/A"; }
    private List<PremioFila>   filasPremios   = new();
    private List<PasantiaFila> filasPasantias = new();

    // ── CAMPOS RELACIONES ────────────────────────────────────
    private int campoAN_Asp = 0;
    private int campoPE_Prac = 0;
    private int campoAC_Area = 0;
    private int campoCI_Car  = 0;

    // ── FILTRO ───────────────────────────────────────────────
    private IEnumerable<Dictionary<string, object?>> ProgramasFiltrados =>
        string.IsNullOrWhiteSpace(filtro)
            ? programas
            : programas.Where(p =>
                ObtenerValor(p,"nombre").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                ObtenerValor(p,"nivel" ).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                ObtenerValor(p,"ciudad").Contains(filtro, StringComparison.OrdinalIgnoreCase));

    // ══ INIT ═════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        listaFacultades     = await Api.ListarAsync("facultad")            ?? new();
        aspectos            = await Api.ListarAsync("aspecto_normativo")   ?? new();
        practicasEstrategia = await Api.ListarAsync("practica_estrategia") ?? new();
        areas               = await Api.ListarAsync("area_conocimiento")   ?? new();
        carInnovaciones     = await Api.ListarAsync("car_innovacion")      ?? new();

        await Task.WhenAll(
            CargarProgramas(),
            CargarAN(), CargarPE(), CargarAC(), CargarCI()
        );
    }

    // ══ CARGA ════════════════════════════════════════════════
    private async Task CargarProgramas()
    {
        cargando = true;
        var p = new Dictionary<string, object?> { ["p_resultado"] = null };
        var (ok, resultados, _) = await Sp.EjecutarSpAsync("sp_listar_programas_completos", p);
        if (ok && resultados.Count > 0)
        {
            var json = resultados[0].Values.FirstOrDefault()?.ToString();
            if (!string.IsNullOrEmpty(json))
                try { programas = ParsearJsonArray(json); } catch { programas = resultados; }
        }
        cargando = false;
    }
    private async Task CargarAN() { registrosAN = await Api.ListarAsync("an_programa") ?? new(); }
    private async Task CargarPE() { registrosPE = await Api.ListarAsync("programa_pe") ?? new(); }
    private async Task CargarAC() { registrosAC = await Api.ListarAsync("programa_ac") ?? new(); }
    private async Task CargarCI() { registrosCI = await Api.ListarAsync("programa_ci") ?? new(); }

    // ══ EXPAND / COLLAPSE ════════════════════════════════════
    private void ToggleExpand(string pid)
    {
        if (expandidos.Contains(pid)) expandidos.Remove(pid);
        else expandidos.Add(pid);
    }

    // ══ PANEL — ABRIR / CERRAR ═══════════════════════════════
    private void AbrirPanelNuevo()
    {
        LimpiarCampos();
        programaActual = null;
        panelModo      = "nuevo";
        panelTab       = "datos";
        panelAbierto   = true;
        mensaje        = string.Empty;
    }

    private void AbrirPanelEditar(Dictionary<string, object?> p)
    {
        programaActual        = p;
        panelModo             = "editar";
        panelTab              = "datos";
        c_nombre              = ObtenerValor(p,"nombre");
        c_tipo                = ObtenerValor(p,"tipo");
        c_nivel               = ObtenerValor(p,"nivel");
        c_fecha_creacion      = ObtenerValor(p,"fecha_creacion");
        c_fecha_cierre        = ObtenerValor(p,"fecha_cierre");
        c_numero_cohortes     = ObtenerValor(p,"numero_cohortes");
        c_cant_graduados      = ObtenerValor(p,"cant_graduados");
        c_fecha_actualizacion = ObtenerValor(p,"fecha_actualizacion");
        c_ciudad              = ObtenerValor(p,"ciudad");
        c_facultad            = int.TryParse(ObtenerValor(p,"facultad"), out int f) ? f : 0;
        filasPremios          = ObtenerDetalles(p,"premios").Select(pr => new PremioFila {
            Nombre           = ObtenerValor(pr,"nombre"),
            EntidadOtorgante = ObtenerValor(pr,"entidad_otorgante"),
            Pais             = ObtenerValor(pr,"pais"),
            Fecha            = DateTime.TryParse(ObtenerValor(pr,"fecha"), out var dt) ? dt : DateTime.Today
        }).ToList();
        filasPasantias        = ObtenerDetalles(p,"pasantias").Select(pa => new PasantiaFila {
            Nombre      = ObtenerValor(pa,"nombre"),
            Empresa     = ObtenerValor(pa,"empresa"),
            Pais        = ObtenerValor(pa,"pais"),
            Descripcion = ObtenerValor(pa,"descripcion")
        }).ToList();
        campoAN_Asp  = 0; campoPE_Prac = 0; campoAC_Area = 0; campoCI_Car = 0;
        panelAbierto = true;
        mensaje      = string.Empty;
    }

    private void AbrirPanelRelaciones(Dictionary<string, object?> p, string tab)
    {
        AbrirPanelEditar(p);
        panelTab = tab;
    }

    private void CerrarPanel() { panelAbierto = false; }

    // ══ CRUD PROGRAMA ════════════════════════════════════════
    private async Task GuardarPrograma()
    {
        var premios = filasPremios.Where(p => !string.IsNullOrEmpty(p.Nombre))
            .Select(p => new { nombre=p.Nombre, descripcion=p.Descripcion, fecha=p.Fecha.ToString("yyyy-MM-dd"), entidad_otorgante=p.EntidadOtorgante, pais=p.Pais }).ToList();
        var pasantias = filasPasantias.Where(p => !string.IsNullOrEmpty(p.Nombre))
            .Select(p => new { nombre=p.Nombre, pais=p.Pais, empresa=p.Empresa, descripcion=p.Descripcion }).ToList();

        bool editando = panelModo == "editar";
        int  idEditar = editando && programaActual != null
            ? (int.TryParse(ObtenerValor(programaActual,"id"), out int n) ? n : 0) : 0;

        var parametros = new Dictionary<string, object?> {
            ["p_nombre"]=Str(c_nombre), ["p_tipo"]=Str(c_tipo), ["p_nivel"]=Str(c_nivel),
            ["p_fecha_creacion"]=Str(c_fecha_creacion), ["p_fecha_cierre"]=Str(c_fecha_cierre),
            ["p_numero_cohortes"]=Str(c_numero_cohortes), ["p_cant_graduados"]=Str(c_cant_graduados),
            ["p_fecha_actualizacion"]=Str(c_fecha_actualizacion), ["p_ciudad"]=Str(c_ciudad),
            ["p_facultad"]=c_facultad,
            ["p_premios"]  = premios.Any()   ? JsonSerializer.Serialize(premios)   : null,
            ["p_pasantias"]= pasantias.Any() ? JsonSerializer.Serialize(pasantias) : null,
        };
        if (editando) parametros["p_numero"] = idEditar;

        string sp = editando ? "sp_actualizar_programa_completo" : "sp_insertar_programa_completo";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, parametros);
        exito = ok; mensaje = ok ? (editando ? "Programa actualizado." : "Programa creado.") : $"Error: {msg}";
        if (ok) { await CargarProgramas(); CerrarPanel(); }
    }

    private async Task EliminarPrograma(Dictionary<string, object?> p)
    {
        int id = int.TryParse(ObtenerValor(p,"id"), out int n) ? n : 0;
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Borrar programa {id} y todos sus detalles?")) return;
        var (ok, _, msg) = await Sp.EjecutarSpAsync("sp_borrar_programa_completo", new() { ["p_numero"]=id });
        exito = ok; mensaje = ok ? "Eliminado correctamente." : $"Error: {msg}";
        if (ok) { expandidos.Remove(ObtenerValor(p,"id")); await CargarProgramas(); }
    }

