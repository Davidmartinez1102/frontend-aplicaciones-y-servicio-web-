    // ══ HELPERS ══════════════════════════════════════════════
    private static object? Str(string? v) => string.IsNullOrWhiteSpace(v) ? null : (object?)v;

    private void LimpiarCampos() {
        c_nombre=c_tipo=c_nivel=c_fecha_creacion=c_fecha_cierre=
        c_numero_cohortes=c_cant_graduados=c_fecha_actualizacion=c_ciudad="";
        c_facultad=0; filasPremios.Clear(); filasPasantias.Clear();
    }

    private string ObtenerValor(Dictionary<string,object?> dic, string clave) =>
        dic.TryGetValue(clave, out var v) && v!=null ? v.ToString() ?? "" : "";

    private string ObtenerNombreEnLista(List<Dictionary<string,object?>> lista, string pk, string val, string campo) {
        var item = lista.FirstOrDefault(x => ObtenerValor(x,pk)==val);
        return item!=null ? ObtenerValor(item,campo) : $"ID:{val}";
    }

    private List<Dictionary<string,object?>> ObtenerDetalles(Dictionary<string,object?> maestro, string clave) {
        if (maestro.TryGetValue(clave, out var val) && val!=null) {
            var s = val.ToString() ?? "";
            if (s.StartsWith("[")) try { return ParsearJsonArray(s); } catch {}
            if (val is List<Dictionary<string,object?>> l) return l;
        }
        return new();
    }

    private string ObtenerEtiquetaAspecto(Dictionary<string,object?> a) =>
        string.Join(" — ", new[]{ ObtenerValor(a,"tipo"), ObtenerValor(a,"descripcion") }.Where(s=>!string.IsNullOrWhiteSpace(s)));

    private string ObtenerEtiquetaAspectoById(string id) {
        var item = aspectos.FirstOrDefault(x => ObtenerValor(x,"id")==id);
        return item!=null ? ObtenerEtiquetaAspecto(item) : $"ID:{id}";
    }

    private string ObtenerEtiquetaArea(Dictionary<string,object?> a) =>
        string.Join(" › ", new[]{ ObtenerValor(a,"gran_area"), ObtenerValor(a,"area"), ObtenerValor(a,"disciplina") }.Where(s=>!string.IsNullOrWhiteSpace(s)));

    private string ObtenerEtiquetaAreaById(string id) {
        var item = areas.FirstOrDefault(x => ObtenerValor(x,"id")==id);
        return item!=null ? ObtenerEtiquetaArea(item) : $"ID:{id}";
    }

    private List<Dictionary<string,object?>> ParsearJsonArray(string json) {
        var lista = new List<Dictionary<string,object?>>();
        var doc   = JsonDocument.Parse(json);
        foreach (var elem in doc.RootElement.EnumerateArray()) {
            var dic = new Dictionary<string,object?>();
            foreach (var prop in elem.EnumerateObject())
                dic[prop.Name] = prop.Value.ValueKind switch {
                    JsonValueKind.String => prop.Value.GetString(),
                    JsonValueKind.Number => prop.Value.TryGetInt32(out int i) ? i : prop.Value.GetDouble(),
                    _ => prop.Value.GetRawText()
                };
            lista.Add(dic);
        }
        return lista;
    }
