@page "/acreditacion"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Acreditaciones</PageTitle>

<div class="container mt-4">
    <h3>Gestión de Acreditaciones</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Acreditación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white">
                @(editando ? "Editar Acreditación" : "Nueva Acreditación")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Resolución (PK)</label>
                        <input class="form-control" type="number" @bind="campoResolucion" disabled="@editando" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Calificación</label>
                        <input class="form-control" @bind="campoCalificacion" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" @bind="campoFechaInicio" placeholder="ej: 2024-01-01" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" @bind="campoFechaFin" placeholder="ej: 2028-01-01" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Programa</label>
                        <select class="form-select" @bind="campoPrograma">
                            <option value="0">-- Seleccione un Programa --</option>
                            @foreach (var p in programas)
                            {
                                <option value="@ObtenerValor(p, "id")">@ObtenerValor(p, "nombre")</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (registros.Any() && !mostrarFormulario)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Resolución</th>
                    <th>Tipo</th>
                    <th>Calificación</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Fin</th>
                    <th>Programa</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerValor(reg, "resolucion")</td>
                        <td>@ObtenerValor(reg, "tipo")</td>
                        <td>@ObtenerValor(reg, "calificacion")</td>
                        <td>@ObtenerValor(reg, "fecha_inicio")</td>
                        <td>@ObtenerValor(reg, "fecha_fin")</td>
                        <td>@ObtenerNombrePrograma(ObtenerValor(reg, "programa"))</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (!mostrarFormulario)
    {
        <div class="alert alert-warning">No hay acreditaciones registradas.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programas = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoResolucion = 0;
    private string campoTipo = string.Empty;
    private string campoCalificacion = string.Empty;
    private string campoFechaInicio = string.Empty;
    private string campoFechaFin = string.Empty;
    private int campoPrograma = 0;

    protected override async Task OnInitializedAsync()
    {
        programas = await Api.ListarAsync("programa") ?? new();
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("acreditacion") ?? new();
        cargando = false;
    }

    private string ObtenerNombrePrograma(string id)
    {
        var p = programas.FirstOrDefault(x => ObtenerValor(x, "id") == id);
        return p != null ? ObtenerValor(p, "nombre") : $"ID: {id}";
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoResolucion = 0; campoTipo = ""; campoCalificacion = "";
        campoFechaInicio = ""; campoFechaFin = ""; campoPrograma = 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoResolucion = int.TryParse(ObtenerValor(reg, "resolucion"), out int r) ? r : 0;
        campoTipo = ObtenerValor(reg, "tipo");
        campoCalificacion = ObtenerValor(reg, "calificacion");
        campoFechaInicio = ObtenerValor(reg, "fecha_inicio");
        campoFechaFin = ObtenerValor(reg, "fecha_fin");
        campoPrograma = int.TryParse(ObtenerValor(reg, "programa"), out int p) ? p : 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (campoPrograma == 0) { exito = false; mensaje = "Debe seleccionar un programa."; return; }

        var datos = new Dictionary<string, object?>
        {
            ["resolucion"] = campoResolucion,
            ["tipo"] = campoTipo,
            ["calificacion"] = campoCalificacion,
            ["fecha_inicio"] = campoFechaInicio,
            ["fecha_fin"] = campoFechaFin,
            ["programa"] = campoPrograma
        };

        if (editando)
        {
            datos.Remove("resolucion");
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Actualizar Acreditación #{campoResolucion}?");
            if (!confirmar) return;
            var r = await Api.ActualizarAsync("acreditacion", "resolucion", campoResolucion.ToString(), datos);
            exito = r.exito; mensaje = r.mensaje;
        }
        else
        {
            var r = await Api.CrearAsync("acreditacion", datos);
            exito = r.exito; mensaje = r.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string resStr = ObtenerValor(reg, "resolucion");
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar Acreditación resolución #{resStr}?");
        if (!confirmar) return;
        var r = await Api.EliminarAsync("acreditacion", "resolucion", resStr);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerValor(Dictionary<string, object?> dic, string clave)
    {
        if (dic.TryGetValue(clave, out var val) && val != null) return val.ToString() ?? "";
        return "";
    }
}
