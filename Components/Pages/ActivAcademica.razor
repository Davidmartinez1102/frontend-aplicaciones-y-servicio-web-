@page "/activ-academica"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Actividades Académicas</PageTitle>

<div class="container mt-4">
    <h3>Gestión de Actividades Académicas</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Actividad Académica</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white">
                @(editando ? "Editar Actividad Académica" : "Nueva Actividad Académica")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" maxlength="20" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Núm. Créditos</label>
                        <input class="form-control" type="number" @bind="campoNumCreditos" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Área de Formación</label>
                        <input class="form-control" @bind="campoAreaFormacion" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">H. Acompañadas</label>
                        <input class="form-control" type="number" @bind="campoHAcom" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">H. Independientes</label>
                        <input class="form-control" type="number" @bind="campoHIndep" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Idioma</label>
                        <input class="form-control" @bind="campoIdioma" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">¿Es Espejo?</label>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" @bind="campoEspejo" />
                            <label class="form-check-label">Sí</label>
                        </div>
                    </div>
                    @if (campoEspejo)
                    {
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Entidad Espejo</label>
                            <input class="form-control" @bind="campoEntidadEspejo" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">País Espejo</label>
                            <input class="form-control" @bind="campoPaisEspejo" />
                        </div>
                    }
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Diseño (Programa FK, opcional)</label>
                        <select class="form-select" @bind="campoDisenio">
                            <option value="0">-- Ninguno --</option>
                            @foreach (var p in programas)
                            {
                                <option value="@ObtenerValor(p, "id")">@ObtenerValor(p, "nombre")</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (registros.Any() && !mostrarFormulario)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Créditos</th>
                    <th>Área Formación</th>
                    <th>Idioma</th>
                    <th>Espejo</th>
                    <th>Diseño (Prog.)</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerValor(reg, "id")</td>
                        <td>@ObtenerValor(reg, "nombre")</td>
                        <td>@ObtenerValor(reg, "tipo")</td>
                        <td>@ObtenerValor(reg, "num_creditos")</td>
                        <td>@ObtenerValor(reg, "area_formacion")</td>
                        <td>@ObtenerValor(reg, "idioma")</td>
                        <td>@(ObtenerValor(reg, "espejo") == "True" || ObtenerValor(reg, "espejo") == "1" ? "Sí" : "No")</td>
                        <td>@ObtenerNombrePrograma(ObtenerValor(reg, "disenio"))</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (!mostrarFormulario)
    {
        <div class="alert alert-warning">No hay actividades académicas registradas.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programas = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoId = 0;
    private string campoNombre = string.Empty;
    private int campoNumCreditos = 0;
    private string campoTipo = string.Empty;
    private string campoAreaFormacion = string.Empty;
    private int campoHAcom = 0;
    private int campoHIndep = 0;
    private string campoIdioma = string.Empty;
    private bool campoEspejo = false;
    private string campoEntidadEspejo = string.Empty;
    private string campoPaisEspejo = string.Empty;
    private int campoDisenio = 0;

    protected override async Task OnInitializedAsync()
    {
        programas = await Api.ListarAsync("programa") ?? new();
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("activ_academica") ?? new();
        cargando = false;
    }

    private string ObtenerNombrePrograma(string id)
    {
        if (string.IsNullOrEmpty(id) || id == "0") return "N/A";
        var p = programas.FirstOrDefault(x => ObtenerValor(x, "id") == id);
        return p != null ? ObtenerValor(p, "nombre") : $"ID: {id}";
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = 0; campoNombre = ""; campoNumCreditos = 0; campoTipo = "";
        campoAreaFormacion = ""; campoHAcom = 0; campoHIndep = 0; campoIdioma = "";
        campoEspejo = false; campoEntidadEspejo = ""; campoPaisEspejo = ""; campoDisenio = 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(ObtenerValor(reg, "id"), out int id) ? id : 0;
        campoNombre = ObtenerValor(reg, "nombre");
        campoNumCreditos = int.TryParse(ObtenerValor(reg, "num_creditos"), out int nc) ? nc : 0;
        campoTipo = ObtenerValor(reg, "tipo");
        campoAreaFormacion = ObtenerValor(reg, "area_formacion");
        campoHAcom = int.TryParse(ObtenerValor(reg, "h_acom"), out int ha) ? ha : 0;
        campoHIndep = int.TryParse(ObtenerValor(reg, "h_indep"), out int hi) ? hi : 0;
        campoIdioma = ObtenerValor(reg, "idioma");
        string espStr = ObtenerValor(reg, "espejo");
        campoEspejo = espStr == "True" || espStr == "1" || espStr == "true";
        campoEntidadEspejo = ObtenerValor(reg, "entidad_espejo");
        campoPaisEspejo = ObtenerValor(reg, "pais_espejo");
        campoDisenio = int.TryParse(ObtenerValor(reg, "disenio"), out int d) ? d : 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrWhiteSpace(campoNombre)) { exito = false; mensaje = "El nombre es obligatorio."; return; }

        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["nombre"] = campoNombre,
            ["num_creditos"] = campoNumCreditos,
            ["tipo"] = campoTipo,
            ["area_formacion"] = campoAreaFormacion,
            ["h_acom"] = campoHAcom,
            ["h_indep"] = campoHIndep,
            ["idioma"] = campoIdioma,
            ["espejo"] = campoEspejo ? 1 : 0,
            ["entidad_espejo"] = campoEntidadEspejo,
            ["pais_espejo"] = campoPaisEspejo,
            ["disenio"] = campoDisenio == 0 ? null : campoDisenio
        };

        if (editando)
        {
            datos.Remove("id");
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Actualizar Actividad #{campoId}?");
            if (!confirmar) return;
            var r = await Api.ActualizarAsync("activ_academica", "id", campoId.ToString(), datos);
            exito = r.exito; mensaje = r.mensaje;
        }
        else
        {
            var r = await Api.CrearAsync("activ_academica", datos);
            exito = r.exito; mensaje = r.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string idStr = ObtenerValor(reg, "id");
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar Actividad #{idStr}?");
        if (!confirmar) return;
        var r = await Api.EliminarAsync("activ_academica", "id", idStr);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerValor(Dictionary<string, object?> dic, string clave)
    {
        if (dic.TryGetValue(clave, out var val) && val != null) return val.ToString() ?? "";
        return "";
    }
}
