@page "/registro-calificado"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Registros Calificados</PageTitle>

<div class="container mt-4">
    <h3>Gestión de Registros Calificados</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Registro Calificado</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white">
                @(editando ? "Editar Registro Calificado" : "Nuevo Registro Calificado")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Código (PK)</label>
                        <input class="form-control" type="number" @bind="campoCodigo" disabled="@editando" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Cant. Créditos</label>
                        <input class="form-control" @bind="campoCantCreditos" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Horas Acompañadas</label>
                        <input class="form-control" @bind="campoHoraAcom" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Horas Independientes</label>
                        <input class="form-control" @bind="campoHoraInd" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Metodología</label>
                        <input class="form-control" @bind="campoMetodologia" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" type="date" @bind="campoFechaInicio" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" type="date" @bind="campoFechaFin" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Duración (Años)</label>
                        <input class="form-control" @bind="campoDuracionAnios" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Duración (Semestres)</label>
                        <input class="form-control" @bind="campoDuracionSemestres" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tipo Titulación</label>
                        <input class="form-control" @bind="campoTipoTitulacion" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Programa</label>
                        <select class="form-select" @bind="campoPrograma">
                            <option value="0">-- Seleccione un Programa --</option>
                            @foreach (var p in programas)
                            {
                                <option value="@ObtenerValor(p, "id")">@ObtenerValor(p, "nombre")</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (registros.Any() && !mostrarFormulario)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Créditos</th>
                    <th>Metodología</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Fin</th>
                    <th>Duración Años</th>
                    <th>Tipo Titulación</th>
                    <th>Programa</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerValor(reg, "codigo")</td>
                        <td>@ObtenerValor(reg, "cant_creditos")</td>
                        <td>@ObtenerValor(reg, "metodologia")</td>
                        <td>@FormatearFecha(ObtenerValor(reg, "fecha_inicio"))</td>
                        <td>@FormatearFecha(ObtenerValor(reg, "fecha_fin"))</td>
                        <td>@ObtenerValor(reg, "duracion_anios")</td>
                        <td>@ObtenerValor(reg, "tipo_titulacion")</td>
                        <td>@ObtenerNombrePrograma(ObtenerValor(reg, "programa"))</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (!mostrarFormulario)
    {
        <div class="alert alert-warning">No hay registros calificados.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programas = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoCodigo = 0;
    private string campoCantCreditos = string.Empty;
    private string campoHoraAcom = string.Empty;
    private string campoHoraInd = string.Empty;
    private string campoMetodologia = string.Empty;
    private DateTime campoFechaInicio = DateTime.Today;
    private DateTime campoFechaFin = DateTime.Today;
    private string campoDuracionAnios = string.Empty;
    private string campoDuracionSemestres = string.Empty;
    private string campoTipoTitulacion = string.Empty;
    private int campoPrograma = 0;

    protected override async Task OnInitializedAsync()
    {
        programas = await Api.ListarAsync("programa") ?? new();
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("registro_calificado") ?? new();
        cargando = false;
    }

    private string ObtenerNombrePrograma(string id)
    {
        var p = programas.FirstOrDefault(x => ObtenerValor(x, "id") == id);
        return p != null ? ObtenerValor(p, "nombre") : $"ID: {id}";
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoCodigo = 0; campoCantCreditos = ""; campoHoraAcom = ""; campoHoraInd = "";
        campoMetodologia = ""; campoFechaInicio = DateTime.Today; campoFechaFin = DateTime.Today;
        campoDuracionAnios = ""; campoDuracionSemestres = ""; campoTipoTitulacion = ""; campoPrograma = 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoCodigo = int.TryParse(ObtenerValor(reg, "codigo"), out int c) ? c : 0;
        campoCantCreditos = ObtenerValor(reg, "cant_creditos");
        campoHoraAcom = ObtenerValor(reg, "hora_acom");
        campoHoraInd = ObtenerValor(reg, "hora_ind");
        campoMetodologia = ObtenerValor(reg, "metodologia");
        campoFechaInicio = DateTime.TryParse(ObtenerValor(reg, "fecha_inicio"), out var fi) ? fi : DateTime.Today;
        campoFechaFin = DateTime.TryParse(ObtenerValor(reg, "fecha_fin"), out var ff) ? ff : DateTime.Today;
        campoDuracionAnios = ObtenerValor(reg, "duracion_anios");
        campoDuracionSemestres = ObtenerValor(reg, "duracion_semestres");
        campoTipoTitulacion = ObtenerValor(reg, "tipo_titulacion");
        campoPrograma = int.TryParse(ObtenerValor(reg, "programa"), out int p) ? p : 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (campoPrograma == 0) { exito = false; mensaje = "Debe seleccionar un programa."; return; }

        var datos = new Dictionary<string, object?>
        {
            ["codigo"] = campoCodigo,
            ["cant_creditos"] = campoCantCreditos,
            ["hora_acom"] = campoHoraAcom,
            ["hora_ind"] = campoHoraInd,
            ["metodologia"] = campoMetodologia,
            ["fecha_inicio"] = campoFechaInicio.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin.ToString("yyyy-MM-dd"),
            ["duracion_anios"] = campoDuracionAnios,
            ["duracion_semestres"] = campoDuracionSemestres,
            ["tipo_titulacion"] = campoTipoTitulacion,
            ["programa"] = campoPrograma
        };

        if (editando)
        {
            datos.Remove("codigo");
            var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Actualizar Registro #{campoCodigo}?");
            if (!confirmar) return;
            var r = await Api.ActualizarAsync("registro_calificado", "codigo", campoCodigo.ToString(), datos);
            exito = r.exito; mensaje = r.mensaje;
        }
        else
        {
            var r = await Api.CrearAsync("registro_calificado", datos);
            exito = r.exito; mensaje = r.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string cod = ObtenerValor(reg, "codigo");
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar Registro #{cod}?");
        if (!confirmar) return;
        var r = await Api.EliminarAsync("registro_calificado", "codigo", cod);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerValor(Dictionary<string, object?> dic, string clave)
    {
        if (dic.TryGetValue(clave, out var val) && val != null) return val.ToString() ?? "";
        return "";
    }

    private string FormatearFecha(string fecha)
    {
        if (DateTime.TryParse(fecha, out var dt)) return dt.ToString("yyyy-MM-dd");
        return fecha;
    }
}
